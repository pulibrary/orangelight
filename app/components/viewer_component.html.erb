<%# app/components/viewer_component.html.erb %>
<%# This component renders the Figgy viewer using the manifest_url from the manifest_url method %>
<%= byebug %>
<% if manifest_url.present? %>
  <div class="intrinsic-container intrinsic-container-16x9" id="viewer-container">
    <iframe
      allowfullscreen="true"
      title="Digital content viewer"
      id="iframe-1"
  src="<%= "#{ENV['FIGGY_URL'] || 'https://figgy.princeton.edu'}/viewer#?manifest=#{manifest_url}&config=#{ENV['FIGGY_URL'] || 'https://figgy.princeton.edu'}/uv/uv_config.json" %>"
      style="width: 100%; height: 600px; border: none;"
    ></iframe>
  </div>
<% end %>
