<% if document.uuid? && thumbnail_display.present? %>
    <%= content_tag(
    :div,
    image_tag(thumbnail_display, alt: ""),
    class: "document-thumbnail",
    data: identifier_data)
   %>
<% else %>
  <%= content_tag(
      :div,
      content_tag(:div, nil, class: "default"),
      class: 'document-thumbnail',
      data: identifier_data)
  %>
<% end %>
